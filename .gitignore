# Built application files
*.apk
*.aab
*.ap_

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
build/

# Local configuration file (sdk path, etc). Ignored — Pulseboard is public
# OSS and each contributor's sdk.dir differs. Android Studio auto-creates
# local.properties on first sync.
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ / Android Studio
*.iml
.idea/
!.idea/runConfigurations.xml

# Keystore files
*.jks
*.keystore

# External native build folder generated in Android Studio 2.2 and later.
.externalNativeBuild
.cxx/

# Google Services (e.g. APIs or Firebase)
google-services.json

# Kotlin
.kotlin/

# macOS
.DS_Store

# Claude Code / agent artifacts
.claude/
.remember/
.omx/
.goose/
.kiro/

# Freshly baked APKs (go to GitHub Releases, not git)
NetworkMonitorCN-*.apk
