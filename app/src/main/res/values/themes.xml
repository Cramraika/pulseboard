<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Pulseboard light theme — brand cyan primary + lime accent.
         Dark-mode port lives in values-night/themes.xml. -->
    <style name="Theme.Pulseboard" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryDark">@color/brand_primary_muted</item>
        <item name="colorSecondary">@color/brand_accent</item>
        <item name="colorError">@color/status_poor</item>
        <item name="android:windowBackground">@color/neutral_50</item>
        <item name="android:statusBarColor">@color/brand_primary_muted</item>
    </style>
</resources>
