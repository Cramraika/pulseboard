<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Pulseboard theme — brand cyan primary + lime accent.
         Light-only theme retained (per prior note: layouts hard-code light colors;
         DayNight caused the onboarding EditText to render white-on-white in dark mode).
         Dark-mode port available in values-night/themes.xml (additive, off-by-default at layout level). -->
    <style name="Theme.NetworkMonitorCN" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryDark">@color/brand_primary_muted</item>
        <item name="colorSecondary">@color/brand_accent</item>
        <item name="colorError">@color/status_poor</item>
        <item name="android:windowBackground">@color/neutral_50</item>
        <item name="android:statusBarColor">@color/brand_primary_muted</item>
    </style>
</resources>
