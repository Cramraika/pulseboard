<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Pulseboard dark-mode theme — mirror of day theme with dark-mode-first neutrals.
         Layouts currently hard-code light colors, so this theme is additive and won't
         take effect until layouts are refactored to use theme attrs (e.g. ?attr/colorSurface).
         Ported from docs/design/palette.md 2026-04-20. -->
    <style name="Theme.NetworkMonitorCN" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryDark">@color/brand_primary_muted</item>
        <item name="colorSecondary">@color/brand_accent</item>
        <item name="colorError">@color/status_poor</item>
        <item name="android:windowBackground">@color/neutral_950</item>
        <item name="android:statusBarColor">@color/neutral_900</item>
    </style>
</resources>
