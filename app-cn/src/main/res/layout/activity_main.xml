<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hi,"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Background monitoring is active. Analysis happens in the Sheet."
            android:textSize="12sp"
            android:textColor="#4F46E5"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tvLastSentHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No data yet"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tvSmartflo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="smartflo:   —"
            android:textSize="13sp"
            android:textColor="#1A1A2E"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvGateway"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="gateway:    —"
            android:textSize="13sp"
            android:textColor="#1A1A2E"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvCloudflare"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="cloudflare: —"
            android:textSize="13sp"
            android:textColor="#1A1A2E"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvDns"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="dns:        —"
            android:textSize="13sp"
            android:textColor="#1A1A2E"
            android:fontFamily="monospace"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tvFooter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="First flush completes at the next 15-minute wall-clock mark."
            android:textSize="11sp"
            android:textColor="#777777"
            android:lineSpacingMultiplier="1.3" />

    </LinearLayout>
</ScrollView>
